# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage
/test-results
/playwright-report
/playwright/.cache

# eval harness do funil IA — LOCAL only. A fonte da verdade em prod é o embutido
# src/app/api/admin/funnel-eval/cases.data.ts (gerado por _eval/gen-cases-data.ts).
/_eval

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env
.env.diagnostic

# script logs (gerados por scripts/diagnose-* e scripts/fix-*)
/scripts/logs/

# QA artefatos (screenshots, dumps de auth, etc — gerados localmente)
/qa-artifacts/

# scripts ad-hoc de verificação manual (_prefixados)
/scripts/_*

# Sentry build plugin (gerado pelo @sentry/wizard, pode conter authToken)
.env.sentry-build-plugin

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma
/prisma/*.db
/prisma/*.db-journal
.gstack/

# git worktrees (sprints/features isolados)
.worktrees/

# Brainstorming visual companion (não versionar)
.superpowers/

# Lock de scheduled tasks (por-sessão, não versionar)
.claude/scheduled_tasks.lock
