# ===========================================
# PDV ÓTICA - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores

# DATABASE
DATABASE_URL="postgresql://user:password@host:5432/database"
# Pool de conexões Prisma (default Neon: 10). Ajustar para evitar P2024.
PRISMA_CONNECTION_LIMIT="10"

# NEXTAUTH
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="sua-chave-secreta-aqui"

# NEXT.JS
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# development | production | test (NextJS define automaticamente, mas alguns
# scripts npm/CI precisam explícito)
NODE_ENV="development"

# LOGGER (src/lib/logger.ts) — debug | info | warn | error (default: info)
LOG_LEVEL="info"

# SEED — quando "true" libera POST /api/permissions/seed e seeds afins.
# Manter "false" em produção; ligar pontualmente quando precisar repropagar.
SEED_ENABLED="false"

# VERCEL (produção)
VERCEL_URL=""

# ANALYTICS — PostHog (free tier até 1M eventos/mês)
# Crie projeto em https://us.posthog.com → Settings → Project API key
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# SUPABASE STORAGE (upload de receita médica)
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# ANTHROPIC (OCR de receita)
ANTHROPIC_API_KEY=""

# ASAAS (cobrança recorrente)
# Sandbox: https://sandbox.asaas.com → Integrações → API
# Chave de produção começa com $aact_prod_*, sandbox com $aact_test_*
# O cliente Asaas detecta automaticamente pelo prefixo da chave.
ASAAS_API_KEY=""
# Token compartilhado para validar webhook (gere em Configurações → Notificações Webhook)
ASAAS_WEBHOOK_TOKEN=""

# FOCUS NFe (emissão fiscal NFC-e/NF-e) — DESABILITADO POR PADRÃO
# Quando vazio, /api/fiscal/nfce/emit retorna 503 e o sistema NÃO emite documentos
# fiscais. Emissão é responsabilidade do contratante (Termos de Uso cláusula 2).
# Para ligar: criar conta em https://focusnfe.com.br e gerar token.
FOCUS_NFE_TOKEN=""
FOCUS_NFE_ENV="homologacao"   # ou "producao"
# Base URL do Focus NFe (default usa o produtivo da própria lib; sobrescrever
# apenas para mock/integration tests).
FOCUS_NFE_URL=""
# Segredo HMAC-SHA256 do webhook Focus NFe (Q5.2). Sem isso, qualquer um
# pode forjar mudança de fiscalStatus. Configure no painel Focus + Vercel.
FOCUS_NFE_WEBHOOK_SECRET=""

# EVOLUTION API (WhatsApp Business) — DESABILITADO POR PADRÃO
# Self-hosted recomendado: rode Evolution API em VPS (Hetzner ~R$30/mês)
# Docs: https://doc.evolution-api.com/
EVOLUTION_API_URL=""
EVOLUTION_API_KEY=""
EVOLUTION_INSTANCE_NAME=""

# CRON SECRETS (Vercel Cron auth)
CRON_SECRET=""

# SENTRY (Q5.5) — error tracking. Bridge em src/lib/sentry.ts é no-op se
# vazio. Para ativar: `npm i @sentry/nextjs` + `npx @sentry/wizard@latest -i nextjs`.
SENTRY_DSN=""

# CSP (Q5.3) — "report-only" força o modo report-only mesmo em prod (override
# de emergência). Em branco/qualquer outro valor, enforce ativa em produção.
CSP_MODE=""
