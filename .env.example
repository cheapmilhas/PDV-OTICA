# ===========================================
# PDV ÓTICA - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores

# DATABASE
DATABASE_URL="postgresql://user:password@host:5432/database"

# NEXTAUTH
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="sua-chave-secreta-aqui"

# NEXT.JS
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# VERCEL (produção)
VERCEL_URL=""

# ANALYTICS — PostHog (free tier até 1M eventos/mês)
# Crie projeto em https://us.posthog.com → Settings → Project API key
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# SUPABASE STORAGE (upload de receita médica)
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# ANTHROPIC (OCR de receita)
ANTHROPIC_API_KEY=""

# ASAAS (cobrança recorrente)
# Sandbox: https://sandbox.asaas.com → Integrações → API
# Chave de produção começa com $aact_prod_*, sandbox com $aact_test_*
# O cliente Asaas detecta automaticamente pelo prefixo da chave.
ASAAS_API_KEY=""
# Token compartilhado para validar webhook (gere em Configurações → Notificações Webhook)
ASAAS_WEBHOOK_TOKEN=""
