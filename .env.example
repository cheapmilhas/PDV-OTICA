# ===========================================
# PDV ÓTICA - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores

# DATABASE
DATABASE_URL="postgresql://user:password@host:5432/database"
# Pool de conexões Prisma (default Neon: 10). Ajustar para evitar P2024.
PRISMA_CONNECTION_LIMIT="10"

# NEXTAUTH
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="sua-chave-secreta-aqui"

# NEXT.JS
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# development | production | test (NextJS define automaticamente, mas alguns
# scripts npm/CI precisam explícito)
NODE_ENV="development"

# LOGGER (src/lib/logger.ts) — debug | info | warn | error (default: info)
LOG_LEVEL="info"

# SEED — quando "true" libera POST /api/permissions/seed e seeds afins.
# Manter "false" em produção; ligar pontualmente quando precisar repropagar.
SEED_ENABLED="false"

# VERCEL (produção)
VERCEL_URL=""

# ANALYTICS — PostHog (free tier até 1M eventos/mês)
# Crie projeto em https://us.posthog.com → Settings → Project API key
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# SUPABASE STORAGE (upload de receita médica)
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# ANTHROPIC (OCR de receita)
ANTHROPIC_API_KEY=""

# ASAAS (cobrança recorrente)
# Sandbox: https://sandbox.asaas.com → Integrações → API
# Chave de produção começa com $aact_prod_*, sandbox com $aact_test_*
# O cliente Asaas detecta automaticamente pelo prefixo da chave.
ASAAS_API_KEY=""
# Token compartilhado para validar webhook (gere em Configurações → Notificações Webhook)
ASAAS_WEBHOOK_TOKEN=""
# Segredo HMAC-SHA256 do webhook Asaas (Q7.2 P1-7). Defesa em profundidade:
# token bearer pode vazar em logs/proxy; HMAC valida payload + assinatura.
# Configure em Asaas → Notificações → Webhook → "Chave de assinatura".
# Sem isso, validação HMAC é skip (backward compat).
ASAAS_WEBHOOK_HMAC_SECRET=""

# RESEND (emails transacionais)
# Configure uma chave com permissao de envio em https://resend.com/api-keys.
# Em producao, use um dominio verificado no Resend para o remetente.
RESEND_API_KEY=""
EMAIL_FROM="PDV Ótica <noreply@seudominio.com.br>"
EMAIL_REPLY_TO=""
EMAIL_QUEUE_BATCH_LIMIT="20"
EMAIL_QUEUE_MAX_ATTEMPTS="3"

# FOCUS NFe (emissão fiscal NFC-e/NF-e) — DESABILITADO POR PADRÃO
# Quando vazio, /api/fiscal/nfce/emit retorna 503 e o sistema NÃO emite documentos
# fiscais. Emissão é responsabilidade do contratante (Termos de Uso cláusula 2).
# Para ligar: criar conta em https://focusnfe.com.br e gerar token.
FOCUS_NFE_TOKEN=""
FOCUS_NFE_ENV="homologacao"   # ou "producao"
# Base URL do Focus NFe (default usa o produtivo da própria lib; sobrescrever
# apenas para mock/integration tests).
FOCUS_NFE_URL=""
# Segredo HMAC-SHA256 do webhook Focus NFe (Q5.2). Sem isso, qualquer um
# pode forjar mudança de fiscalStatus. Configure no painel Focus + Vercel.
FOCUS_NFE_WEBHOOK_SECRET=""

# EVOLUTION API (WhatsApp Business) — DESABILITADO POR PADRÃO
# Self-hosted recomendado: rode Evolution API em VPS (Hetzner ~R$30/mês)
# Docs: https://doc.evolution-api.com/
EVOLUTION_API_URL=""
EVOLUTION_API_KEY=""
EVOLUTION_INSTANCE_NAME=""

# CRON SECRETS (Vercel Cron auth)
CRON_SECRET=""

# Q8.1.1 — Controle de emergência da suspensão por inadimplência.
# A suspensão normal (PAST_DUE→SUSPENDED) é feita pelo cron de dunning (avisa 3/7/14d).
# ENFORCE_SUSPENSION="false" destrava TODOS os tenants de uma vez (ex.: cobrança/webhook
# quebrado em massa não deve trancar clientes pagantes). Default (vazio/qualquer) = enforce.
ENFORCE_SUSPENSION=""
# SUBSCRIPTION_BYPASS_COMPANY_IDS — CSV de companyIds que ignoram a suspensão
# (libera 1 cliente pontual sem desabilitar para todos). Ex: "co_abc,co_xyz".
SUBSCRIPTION_BYPASS_COMPANY_IDS=""

# SENTRY (Q5.5 + API4) — error tracking.
# Server-side: SENTRY_DSN inicializa @sentry/nextjs via sentry.server.config.ts
# Client-side: NEXT_PUBLIC_SENTRY_DSN inicializa o SDK no browser
# (geralmente o MESMO valor das duas vars; "NEXT_PUBLIC_" expõe pro bundle).
# Sem essas vars, Sentry fica em no-op e zero overhead.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# Para upload automático de source maps no build (stack traces legíveis em prod):
# Gere token em https://sentry.io/settings/auth-tokens/ com escopos:
#   project:releases + org:read
# As 3 vars abaixo precisam estar TODAS setadas pra withSentryConfig ativar.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# CSP (Q5.3) — "report-only" força o modo report-only mesmo em prod (override
# de emergência). Em branco/qualquer outro valor, enforce ativa em produção.
CSP_MODE=""
