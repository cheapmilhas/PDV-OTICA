// Pagamento de comissão do MOTOR NOVO (Bloco 4). Diferente de SellerCommission
// (por filial), aqui a chave é por EMPRESA — o motor novo calcula a comissão no
// nível da empresa (computeSellerCommission ignora filial). Materializa o snapshot
// do valor devido NO MOMENTO do pagamento (regime de caixa) e dispara a despesa
// no ledger (FinanceEntry COMMISSION_EXPENSE). @unique evita pagar 2× o mesmo
// vendedor/mês.
model CommissionPayment {
  id              String   @id @default(cuid())
  companyId       String
  userId          String
  year            Int
  month           Int
  // Snapshot do que o motor calculou no instante do pagamento.
  netSales        Decimal  @db.Decimal(12, 2)
  metaCommission  Decimal  @db.Decimal(10, 2)
  campaignBonus   Decimal  @default(0) @db.Decimal(10, 2)
  totalCommission Decimal  @db.Decimal(10, 2)
  paidAt          DateTime @default(now())
  paidByUserId    String?
  // Glosa REGISTRADA (não descontada automaticamente): quando uma venda do mês
  // é devolvida DEPOIS do pagamento, o pago excede o devido. O dono REGISTRA
  // aqui quanto reconhece a glosar — o sistema só sinaliza "a descontar no
  // próximo fechamento". NÃO abate folha sozinho (decisão trabalhista do dono).
  clawbackAmount  Decimal  @default(0) @db.Decimal(10, 2)
  clawbackAt      DateTime?
  clawbackByUserId String?
  createdAt       DateTime @default(now())

  company  Company @relation(fields: [companyId], references: [id])
  user     User    @relation("CommissionPayments", fields: [userId], references: [id])
  paidBy   User?   @relation("CommissionPaymentsPaidBy", fields: [paidByUserId], references: [id])

  @@unique([companyId, userId, year, month])
  @@index([companyId, year, month])
}

