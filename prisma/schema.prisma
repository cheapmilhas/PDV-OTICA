  defaultGraceDays       Int?     @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  primaryColor          String?
  // Automações de WhatsApp (Fase B2) — liga/desliga por tipo, por ótica.
  // Default OFF: o cron só envia o tipo cuja flag está ligada (e a ótica
  // habilitada+conectada). Os campos *Template guardam a copy customizada
  // (placeholders {chave}); null = usa o texto padrão do sistema.
  waOsReadyEnabled       Boolean @default(false)
  waPostSaleEnabled      Boolean @default(false)
  waBirthdayEnabled      Boolean @default(false)
  waInstallmentDueEnabled Boolean @default(false)
  waOsReadyTemplate       String?
  waPostSaleTemplate      String?
  waBirthdayTemplate      String?
  waInstallmentDueTemplate String?
  // Dias após a entrega da OS para disparar o pós-venda (default 7).
  waPostSaleDays          Int     @default(7)
  // Medição/gestão de IA (Bloco C1). iaAvailable só super admin libera;
  // iaEnabled ambos ligam/desligam; iaMonthlyTokenLimit null = ilimitado.
  iaAvailable           Boolean  @default(false)
  iaEnabled             Boolean  @default(false)
  iaMonthlyTokenLimit   Int?
  // Markup de IA por ótica (Bloco D). null = usa o markup global.
  markupPercentOverride Decimal? @db.Decimal(6, 2)
  // Aceite das boas-práticas anti-bloqueio do WhatsApp (Fase 1). null = não aceito.
  waPracticesAcceptedAt DateTime?
  // Overrides das travas anti-bloqueio por ótica (Fase 2). null = usa o global
  // (WhatsappGlobalConfig); se o global também faltar, cai no default hardcoded.
  waOpenHourOverride       Int?
  waCloseHourOverride      Int?
  waDailyCapOverride       Int?
  waSkipSaturdayOverride   Boolean?
  // Frases-isca do anúncio (Sprint 3, #9 — detecção APROXIMADA de tráfego pago).
  // Se a 1ª mensagem do cliente casa alguma destas, o lead nasce PAID_TRAFFIC em
  // vez de WHATSAPP. Vazio = detecção desligada (a ótica opta por usar). Não é ROI.
