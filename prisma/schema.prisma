  companyId String
  tagId     String
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([companyId, tagId])
  @@map("company_tags")
}

model TicketTag {
  id        String        @id @default(cuid())
  ticketId  String
  tagId     String
  createdAt DateTime      @default(now())
  tag       Tag           @relation(fields: [tagId], references: [id], onDelete: Cascade)
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([ticketId, tagId])
  @@map("ticket_tags")
}

model ActivityLog {
  id        String       @id @default(cuid())
  companyId String
  type      ActivityType
  title     String
  detail    Json?
  actorId   String?
  actorType ActorType    @default(SYSTEM)
  actorName String?
  createdAt DateTime     @default(now())
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@map("activity_logs")
}

model OnboardingChecklist {
  id          String           @id @default(cuid())
  companyId   String           @unique
  startedAt   DateTime         @default(now())
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  steps       OnboardingStep[]

  @@map("onboarding_checklists")
}

model OnboardingStep {
  id          String              @id @default(cuid())
  checklistId String
  stepKey     String
  title       String
  description String?
  order       Int
  isRequired  Boolean             @default(true)
  isCompleted Boolean             @default(false)
  completedAt DateTime?
  completedBy String?
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  checklist   OnboardingChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@unique([checklistId, stepKey])
  @@map("onboarding_steps")
}

model DunningRule {
  id          String        @id @default(cuid())
  name        String
  triggerDays Int
  action      DunningAction
  template    String?
  isActive    Boolean       @default(true)
  order       Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("dunning_rules")
}

model DunningEvent {
  id          String             @id @default(cuid())
  companyId   String
  invoiceId   String
  ruleId      String?
  action      DunningAction
  channel     DunningChannel
  status      DunningEventStatus @default(PENDING)
  sentAt      DateTime?
  errorDetail String?
  createdAt   DateTime           @default(now())
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice     Invoice            @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("dunning_events")
}

model AdminNotification {
  id        String                @id @default(cuid())
  adminId   String?
  type      AdminNotificationType
  title     String
  message   String
  link      String?
  metadata  Json?
  isRead    Boolean               @default(false)
  readAt    DateTime?
  createdAt DateTime              @default(now())
  admin     AdminUser?            @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, isRead, createdAt])
  @@index([isRead, createdAt])
  @@map("admin_notifications")
}

model SLAPolicy {
  id             String         @id @default(cuid())
  name           String
  priority       TicketPriority
  firstResponseH Int
  resolutionH    Int
  isDefault      Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([name, priority])
  @@map("sla_policies")
}

model TicketResponseTemplate {
  id        String   @id @default(cuid())
  title     String
  category  String?
  content   String
  isActive  Boolean  @default(true)
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@map("ticket_response_templates")
}

model SavedFilter {
  id        String    @id @default(cuid())
  adminId   String
  name      String
  page      String
  filters   Json
  isDefault Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  admin     AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, page])
  @@map("saved_filters")
}

model ReportSnapshot {
  id          String     @id @default(cuid())
  type        ReportType
  period      String
  data        Json
  generatedAt DateTime   @default(now())

  @@unique([type, period])
  @@index([type, generatedAt])
  @@map("report_snapshots")
}

model ClientPortalConfig {
  id              String   @id @default(cuid())
  companyId       String   @unique
  canViewInvoices Boolean  @default(true)
  canChangePlan   Boolean  @default(true)
  canUpdateData   Boolean  @default(true)
  canOpenTickets  Boolean  @default(true)
  canViewUsage    Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("client_portal_configs")
}

