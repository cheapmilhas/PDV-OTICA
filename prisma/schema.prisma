model Lead {
  id             String      @id @default(cuid())
  companyId      String
  branchId       String?
  name           String
  phone          String?
  email          String?
  interest       String?
  source         LeadFunnelSource?
  stageId        String
  sellerUserId   String?
  estimatedValue Decimal?    @db.Decimal(12, 2)
  customerId     String?
  quoteId        String?
  lostReason     String?
  // Motivo ESTRUTURADO da perda (Sprint 3, #8). Nullable: leads perdidos ANTES
  // da migração ficam null (não adivinhamos categoria do texto livre antigo).
  // A partir de agora é obrigatório ao marcar como perdido (validado no service).
  lostReasonCategory LostReasonCategory?
  notes          String?
  // IA contexto cliente (Fase 1/2): intenção classificada + estado do match de
  // cliente. intent/contactNotPatient/urgent são SUGESTÃO da IA; o vínculo só
  // vira customerId após confirmação humana (customerMatchConfirmedBy/At).
  intent                     ContactIntent?
  contactNotPatient          Boolean           @default(false)
  urgent                     Boolean           @default(false)
  customerMatchKind          CustomerMatchKind @default(NONE)
  // Cliente SUGERIDO pela IA (match único, ainda não confirmado). O vendedor
  // confirma ("É o João ✓") promovendo-o a customerId, ou recusa. SetNull p/
  // não prender exclusão de cliente. NUNCA é o vínculo efetivo — esse é customerId.
  suggestedCustomerId        String?
  customerMatchConfirmedById String?
  customerMatchConfirmedAt   DateTime?
  // Telemetria de acurácia (Fase 3): intentPredicted guarda o palpite ORIGINAL
  // da IA; intent vira a "verdade atual" quando o humano corrige. Acurácia =
  // comparar os dois. intentCorrectedBy/At registra quem/quando corrigiu.
  intentPredicted            ContactIntent?
  intentCorrectedById        String?
  intentCorrectedAt          DateTime?
  // Confiança (0-1) da última classificação da IA. Persistida p/ auditar por que
  // o auto-move (Fatia 3) avançou ou segurou um card (régua exige >= limiar).
  intentConfidence           Float?
  // Funil Inteligente — Fatia 3 (auto-move): autoria do último movimento + trava
  // humana inteligente. lastMovedBy=USER + lastHumanMoveAt registram que um
  // humano mexeu; aiLockUntilMessageAt guarda o lastMessageAt da conversa no
  // momento da correção — a IA só volta a mover esse card se chegar mensagem MAIS
  // NOVA que isso (conversa evoluiu), evitando desfazer a correção relendo o mesmo
  // texto. NULL = nunca tocado por humano (IA livre).
  lastMovedBy          LeadMover?
  lastHumanMoveAt      DateTime?
  aiLockUntilMessageAt DateTime?
  lastActivityAt DateTime    @default(now())
  deletedAt      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  company  Company   @relation(fields: [companyId], references: [id])
  branch   Branch?   @relation(fields: [branchId], references: [id])
  stage    LeadStage @relation(fields: [stageId], references: [id])
  seller   User?     @relation("LeadSeller", fields: [sellerUserId], references: [id])
  customer Customer? @relation("LeadCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  suggestedCustomer Customer? @relation("LeadSuggestedCustomer", fields: [suggestedCustomerId], references: [id], onDelete: SetNull)
  quote    Quote?    @relation("LeadQuote", fields: [quoteId], references: [id], onDelete: SetNull)
  // Funil Inteligente — Fatia 1: vendas vinculadas a este lead (elo Lead↔Sale).
  // Gravado fail-safe na tx da venda quando há customerId. Sem @unique: um lead
  // pode, em tese, gerar mais de uma venda (re-compra do mesmo cliente).
  sales    Sale[]    @relation("LeadSale")

  @@index([companyId, stageId])
  @@index([companyId, sellerUserId])
  @@index([companyId, deletedAt])
  @@index([companyId, intentPredicted])
}

// Funil Inteligente — Fatia 3: trilha de auditoria APPEND-ONLY do auto-move da IA.
// Uma linha por decisão INTERESSANTE do motor (moveu, hold com sinal positivo, ou
// erro) — o caminho kill-switch-off / sem-sinal NÃO grava (evita amplificação de
// escrita no cron). Serve a dois propósitos:
//  1. observabilidade: o cron async não entrega logs de forma confiável; esta
//     tabela é o canal de leitura confiável ("por que o card moveu/não moveu");
//  2. base da métrica futura "IA moveu vs humano corrigiu = acurácia" (histórico).
// Sem FK p/ Lead (append-only, não deve impedir exclusão de lead; leadId é só
// referência). Multi-tenant: companyId em todo filtro/índice.
model FunnelAutoMoveLog {
  id           String   @id @default(cuid())
  companyId    String
  leadId       String
  // "move" | "hold" | "flag" | "error" (FunnelAction + "error" do catch).
  action       String
  moved        Boolean  @default(false)
  reason       String
  killSwitchOn Boolean  @default(false)
  intent       String?
  confidence   Float?
  // Estado da env FUNNEL_AUTOMOVE_COMPANIES no runtime que rodou (prova de
  // propagação): "set" | "unset". Sem valor cru (não vaza lista de companyIds).
  envSeen      String?
  // Mensagem de erro (só quando action="error") — fica SÓ no banco, nunca no HTTP.
  error        String?
  at           DateTime @default(now())

  @@index([companyId, leadId, at])
  @@index([companyId, action, at])
}

model Sale {
  id                   String               @id @default(cuid())
  companyId            String
  // Número sequencial de exibição por empresa (#000123). Backfilled por createdAt
  // na Migration B (#1 = venda mais antiga); unique por empresa.
  number               Int
  branchId             String
  customerId           String?
  serviceOrderId       String?              @unique
  sellerUserId         String
  status               SaleStatus           @default(OPEN)
  subtotal             Decimal              @default(0) @db.Decimal(12, 2)
  discountTotal        Decimal              @default(0) @db.Decimal(12, 2)
  total                Decimal              @default(0) @db.Decimal(12, 2)
  agreementId          String?
  agreementDiscount    Decimal?             @db.Decimal(12, 2)
  authorizationCode    String?
  fiscalStatus         FiscalStatus         @default(NOT_REQUESTED)
  fiscalModel          String?              // "65" = NFC-e, "55" = NF-e
  fiscalKey            String?              // chave de acesso 44 dígitos
  fiscalXmlUrl         String?
  fiscalPdfUrl         String?
  fiscalNumber         String?              // número sequencial da nota
  fiscalSerie          String?              // série da nota
  fiscalRef            String?              @unique // referência única no provedor (Focus NFe)
  fiscalError          String?              // mensagem amigável de erro
  fiscalSefazCode      Int?                 // código de erro da SEFAZ
  fiscalEmittedAt      DateTime?            // momento da autorização
  fiscalCanceledAt     DateTime?
  fiscalCancelReason   String?
  completedAt          DateTime?
  deletedAt            DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  convertedFromQuoteId String?              @unique
  // Funil Inteligente — Fatia 1: lead que originou esta venda (elo determinístico
  // p/ auto-Ganho). Opcional, SEM @unique. Gravado fail-safe na tx da venda
  // quando casa por customerId. SetNull: não prende exclusão de lead.
  leadId               String?
  cashbackUsed         Decimal              @default(0) @db.Decimal(10, 2)
  legacyId             String?              @unique
  legacySource         String?
  accountsReceivable   AccountReceivable[]
  campaignBonusEntries CampaignBonusEntry[]
  cashbackMovements    CashbackMovement[]
  commissions          Commission[]
  refunds              Refund[]
  agreement            Agreement?           @relation(fields: [agreementId], references: [id])
  branch               Branch               @relation(fields: [branchId], references: [id])
  company              Company              @relation(fields: [companyId], references: [id])
  convertedFromQuote   Quote?               @relation("QuoteToSale", fields: [convertedFromQuoteId], references: [id])
  lead                 Lead?                @relation("LeadSale", fields: [leadId], references: [id], onDelete: SetNull)
  customer             Customer?            @relation(fields: [customerId], references: [id])
  sellerUser           User                 @relation("SaleSeller", fields: [sellerUserId], references: [id])
  serviceOrder         ServiceOrder?        @relation(fields: [serviceOrderId], references: [id])
  items                SaleItem[]
  payments             SalePayment[]
  reservations         StockReservation[]
  warranties           Warranty[]
  cardReceivables      CardReceivable[]
  idempotencyKeys      SaleIdempotency[]
  // Livro de Receitas: receitas cuja ORIGEM foi esta venda (SetNull on delete).
  originPrescriptions  Prescription[]       @relation("PrescriptionOriginSale")

  @@unique([companyId, number])
  @@index([companyId, branchId, createdAt])
  // Auditoria 2026-07-02: a listagem de vendas do PDV filtra por
  // companyId+branchId+status+range(createdAt). Índice equality-first
  // (companyId, branchId, status) + range (createdAt) evita o Filter pós-scan.
  @@index([companyId, branchId, status, createdAt])
  @@index([customerId, createdAt])
  @@index([sellerUserId, createdAt])
  @@index([agreementId])
  @@index([status, completedAt])
  @@index([companyId, completedAt])
  @@index([leadId])
}

/// Q8.2.3: idempotência server-side de POST /api/sales. Um Idempotency-Key
/// repetido (duplo-clique / retry de rede) retorna a venda já criada em vez de
/// duplicar. payloadHash detecta reuso indevido da mesma key com payload diferente.
model SaleIdempotency {
  id          String   @id @default(cuid())
  companyId   String
  key         String
  saleId      String
  payloadHash String
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  sale        Sale     @relation(fields: [saleId], references: [id])

  @@unique([companyId, key])
  @@index([expiresAt])
}

