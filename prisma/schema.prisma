generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Counter {
  id        String  @id @default(cuid())
  companyId String
  key       String
  value     Int     @default(0)
  company   Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, key])
  @@index([companyId])
}

model FrameMeasurement {
  id               String       @id @default(cuid())
  companyId        String
  serviceOrderId   String
  frameWidth       Decimal?     @db.Decimal(5, 1)
  bridgeSize       Decimal?     @db.Decimal(4, 1)
  lensWidth        Decimal?     @db.Decimal(4, 1)
  lensHeight       Decimal?     @db.Decimal(4, 1)
  templeLength     Decimal?     @db.Decimal(4, 1)
  pdRight          Decimal?     @db.Decimal(4, 1)
  pdLeft           Decimal?     @db.Decimal(4, 1)
  heightRight      Decimal?     @db.Decimal(4, 1)
  heightLeft       Decimal?     @db.Decimal(4, 1)
  frameModel       String?
  frameColor       String?
  frameMaterial    String?
  measuredByUserId String?
  measuredAt       DateTime     @default(now())
  observations     String?
  company          Company      @relation(fields: [companyId], references: [id])
  measuredBy       User?        @relation("FrameMeasurer", fields: [measuredByUserId], references: [id])
  serviceOrder     ServiceOrder @relation(fields: [serviceOrderId], references: [id])

  @@index([serviceOrderId])
  @@index([companyId])
}

model CashRegister {
  id             String      @id @default(cuid())
  companyId      String
  branchId       String
  name           String
  code           String
  description    String?
  allowNegative  Boolean     @default(false)
  requireBlind   Boolean     @default(false)
  printerType    String?
  printerAddress String?
  active         Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  branch         Branch      @relation(fields: [branchId], references: [id])
  company        Company     @relation(fields: [companyId], references: [id])
  cashShifts     CashShift[]

  @@unique([companyId, code])
  @@index([branchId, active])
}

model CardFeeRule {
  id             String   @id @default(cuid())
  companyId      String
  brand          String
  paymentType    String
  installments   Int      @default(1)
  feePercent     Decimal  @db.Decimal(5, 4)
  feeFixed       Decimal  @default(0) @db.Decimal(10, 2)
  settlementDays Int
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  company        Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, brand, paymentType, installments])
  @@index([companyId, active])
}

model Company {
  id                      String                   @id @default(cuid())
  name                    String
  tradeName               String?
  cnpj                    String?                  @unique
  address                 String?
  city                    String?
  state                   String?
  zipCode                 String?
  phone                   String?
  email                   String?
  website                 String?
  logoPath                String?
  settings                Json?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  slug                    String?                  @unique
  onboardingStep          Int                      @default(0)
  onboardingDoneAt        DateTime?
  isBlocked               Boolean                  @default(false)
  blockedReason           String?
  blockedAt               DateTime?
  leadSource              String?
  referredByCompanyId     String?
  billingEmail            String?
  billingPhone            String?
  billingName             String?
  healthScore             Int?
  healthCategory          HealthCategory?
  healthUpdatedAt         DateTime?
  networkId               String?
  isHeadquarters          Boolean                  @default(false)
  accessEnabled           Boolean                  @default(false)
  accessEnabledAt         DateTime?
  accessEnabledBy         String?
  onboardingStatus        OnboardingStatus         @default(PENDING_INVITE)
  onboardingCompletedAt   DateTime?
  maxUsers                Int                      @default(3)
  maxProducts             Int                      @default(500)
  maxBranches             Int                      @default(1)
  acquisitionChannel      String?
  segment                 CompanySegment?
  sourceDetail            String?
  contractStart           DateTime?
  contractEnd             DateTime?
  quickNote               String?
  accountsPayable         AccountPayable[]
  accountsReceivable      AccountReceivable[]
  agreements              Agreement[]
  auditLogs               AuditLog[]
  billingEvents           BillingEvent[]
  branches                Branch[]
  brands                  Brand[]
  campaignBonusEntries    CampaignBonusEntry[]
  cardFeeRules            CardFeeRule[]
  commissionPayments      CommissionPayment[]
  cashRegisters           CashRegister[]
  cashShifts              CashShift[]
  categories              Category[]
  chartOfAccounts         ChartOfAccounts[]
  colors                  Color[]
  commissions             Commission[]
  commissionRules         CommissionRule[]
  sellerCommissionTiers   SellerCommissionTier[]
  network                 Network?                 @relation("NetworkCompanies", fields: [networkId], references: [id])
  companySettings         CompanySettings?         @relation("CompanySettings")
  counters                Counter[]
  customers               Customer[]
  dreReports              DREReport[]
  dailyAggs               DailyAgg[]
  doctors                 Doctor[]
  financeAccounts         FinanceAccount[]
  financeEntries          FinanceEntry[]
  financeEntryRetries     FinanceEntryRetry[]
  frameMeasurements       FrameMeasurement[]
  globalAudits            GlobalAudit[]
  impersonations          ImpersonationSession[]
  inventoryLots           InventoryLot[]
  labs                    Lab[]
  lensTreatments          LensTreatment[]          @relation("CompanyLensTreatments")
  loyaltyPoints           LoyaltyPoints[]
  loyaltyProgram          LoyaltyProgram?
  prescriptions           Prescription[]
  products                Product[]
  productCampaigns        ProductCampaign[]
  quotes                  Quote[]
  reconciliationBatches   ReconciliationBatch[]
  reconciliationRules     ReconciliationRule[]
  reconciliationTemplates ReconciliationTemplate[]
  refunds                 Refund[]
  sales                   Sale[]
  serviceOrders           ServiceOrder[]
  shapes                  Shape[]
  stockAdjustments        StockAdjustment[]
  stockMovements          StockMovement[]
  stockReservations       StockReservation[]
  subscriptions           Subscription[]
  suppliers               Supplier[]
  supportTickets          SupportTicket[]
  companyNotifications    CompanyNotification[]
  systemRules             SystemRule[]
  domains                 TenantDomain[]
  usageMetrics            UsageMetric[]
  users                   User[]
  warranties              Warranty[]
  activityLogs            ActivityLog[]
  clientPortalConfig      ClientPortalConfig?
  companyNotes            CompanyNote[]
  companyTags             CompanyTag[]
  contactGoals            ContactGoal[]            @relation("ContactGoals")
  crmContacts             CrmContact[]             @relation("CrmContacts")
  crmSettings             CrmSettings?             @relation("CrmSettings")
  customerReminders       CustomerReminder[]       @relation("CustomerReminders")
  dunningEvents           DunningEvent[]
  healthScores            HealthScore[]
  invites                 Invite[]
  messageTemplates        MessageTemplate[]        @relation("MessageTemplates")
  headquartersOf          Network?                 @relation("NetworkHeadquarters")
  onboardingChecklist     OnboardingChecklist?
  stockTransfers          StockTransfer[]
  usageSnapshots          UsageSnapshot[]
  cardReceivables         CardReceivable[]
  recurringExpenses       RecurringExpense[]
  saasEmailLogs           SaasEmailLog[]
  whatsappConnection      WhatsappConnection?
  whatsappConversations   WhatsappConversation[]
  whatsappMessages        WhatsappMessageLog[]
  leads                   Lead[]
  leadStages              LeadStage[]
  aiTokenUsages           AiTokenUsage[]

  @@index([networkId])
  @@index([onboardingStatus])
  @@index([segment])
  // Página Saúde: filtra/ordena por health; sem isto = seq scan + sort.
  @@index([healthCategory, healthScore])
  // Listas do admin ordenam por createdAt (com tiebreaker por id).
  @@index([createdAt])
}

model Branch {
  id                    String                   @id @default(cuid())
  companyId             String
  name                  String
  code                  String?
  address               String?
  city                  String?
  state                 String?
  zipCode               String?
  phone                 String?
  stateRegistration     String?
  nfeSeries             Int?
  lastNfeNumber         Int?
  // Configuração fiscal NFC-e (Focus NFe)
  fiscalEnabled         Boolean                  @default(false)
  fiscalRegime          String?                  // "SIMPLES_NACIONAL" | "LUCRO_PRESUMIDO" | "LUCRO_REAL"
  fiscalCsosn           String?                  // ex: "102" (Simples sem permissão de crédito)
  fiscalCst             String?                  // para regime não-Simples
  fiscalCfopPadrao      String?                  // ex: "5102" (venda mesma UF)
  fiscalNcmPadrao       String?                  // ex: "9001.40" (lentes de contato/óculos)
  fiscalAmbiente        String?                  // "HOMOLOGACAO" | "PRODUCAO"
  fiscalSerieNfce       Int?                     @default(1)
  fiscalProximoNumero   Int?                     @default(1)
  fiscalCscId           String?                  // Código de Segurança do Contribuinte ID
  fiscalCscToken        String?                  // CSC Token
  active                Boolean                  @default(true)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  accountsPayable       AccountPayable[]
  accountsReceivable    AccountReceivable[]
  auditLogs             AuditLog[]
  company               Company                  @relation(fields: [companyId], references: [id])
  campaignBonusEntries  CampaignBonusEntry[]
  campaignProgress      CampaignSellerProgress[]
  cashMovements         CashMovement[]
  cashRegisters         CashRegister[]
  shifts                CashShift[]
  cashbackConfig        CashbackConfig?
  commissionConfig      CommissionConfig?
  originCustomers       Customer[]               @relation("BranchOriginCustomers")
  customerCashbacks     CustomerCashback[]
  customerContacts      CustomerContact[]
  dreReports            DREReport[]
  dailyAggs             DailyAgg[]
  financeAccounts       FinanceAccount[]
  financeEntries        FinanceEntry[]
  inventoryLots         InventoryLot[]
  prescriptions         Prescription[]
  productCampaigns      ProductCampaign[]
  quotes                Quote[]
  reconciliationBatches ReconciliationBatch[]
  refunds               Refund[]
  reminders             Reminder[]
  reminderConfig        ReminderConfig?
  sales                 Sale[]
  salesGoals            SalesGoal[]
  sellerCommissions     SellerCommission[]
  serviceOrders         ServiceOrder[]
  stockAdjustments      StockAdjustment[]
  stockMovements        StockMovement[]          @relation("StockMovementBranch")
  stockMovementsSource  StockMovement[]          @relation("StockMovementSource")
  stockMovementsTarget  StockMovement[]          @relation("StockMovementTarget")
  stockReservations     StockReservation[]
  userBranches          UserBranch[]
  branchStocks          BranchStock[]
  contactGoals          ContactGoal[]            @relation("BranchContactGoals")
  transfersFrom         StockTransfer[]          @relation("TransferFrom")
  transfersTo           StockTransfer[]          @relation("TransferTo")
  cardReceivables       CardReceivable[]
  recurringExpenses     RecurringExpense[]
  leads                 Lead[]

  @@unique([companyId, code])
  @@index([companyId, name])
}

model User {
  id                         String                   @id @default(cuid())
  companyId                  String
  name                       String
  // Q8.4: único POR EMPRESA (não global) — permite o mesmo email/login em
  // empresas diferentes (dono com 2 lojas, funcionário em 2 óticas). A unicidade
  // real é um índice ÚNICO case-insensitive (companyId, lower(email)) criado via
  // migration manual (mesmo padrão de Customer M7) — NÃO declarado como @@unique
  // aqui de propósito, senão o Prisma esperaria um índice case-sensitive e
  // acusaria drift. Aplicação trata P2002 na criação; login em src/auth.ts.
  email                      String
  passwordHash               String
  role                       UserRole
  active                     Boolean                  @default(true)
  isSystem                   Boolean                  @default(false)  // usuário-robô (IA). Excluído da tela de equipe.
  defaultCommissionPercent   Decimal?                 @db.Decimal(5, 2)
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
  accountsPayableCreated     AccountPayable[]         @relation("AccountPayableCreator")
  accountsPayablePaid        AccountPayable[]         @relation("AccountPayablePayer")
  accountsReceivableCreated  AccountReceivable[]      @relation("AccountReceivableCreator")
  accountsReceivableReceived AccountReceivable[]      @relation("AccountReceivableReceiver")
  logs                       AuditLog[]
  campaignBonusEntries       CampaignBonusEntry[]     @relation("BonusSeller")
  campaignProgress           CampaignSellerProgress[] @relation("CampaignProgress")
  cashMovementsCreated       CashMovement[]           @relation("CashMovementCreator")
  shiftsClosed               CashShift[]              @relation("ShiftCloser")
  shiftsOpened               CashShift[]              @relation("ShiftOpener")
  cashbackMovementsCreated   CashbackMovement[]       @relation("CashbackMovementCreatedBy")
  commissions                Commission[]
  contactsExecuted           CustomerContact[]        @relation("ContactExecutedBy")
  frameMeasurementsTaken     FrameMeasurement[]       @relation("FrameMeasurer")
  prescriptionsCreated       Prescription[]           @relation("PrescriptionCreator")
  barcodesCreated            ProductBarcode[]         @relation("BarcodeCreator")
  campaignsCreated           ProductCampaign[]        @relation("CampaignCreatedBy")
  qualityChecks              QualityChecklist[]       @relation("QualityChecker")
  quotesConverted            Quote[]                  @relation("QuoteConverter")
  quotesAsSeller             Quote[]                  @relation("QuoteSeller")
  quoteFollowUps             QuoteFollowUp[]          @relation("QuoteFollowUpCreator")
  remindersDismissed         Reminder[]               @relation("ReminderDismissedBy")
  salesAsSeller              Sale[]                   @relation("SaleSeller")
  paymentsReceived           SalePayment[]            @relation("PaymentReceiver")
  sellerCommissions          SellerCommission[]       @relation("SellerCommissions")
  commissionPayments         CommissionPayment[]      @relation("CommissionPayments")
  commissionPaymentsPaidBy   CommissionPayment[]      @relation("CommissionPaymentsPaidBy")
  sellerCommissionTiers      SellerCommissionTier[]   @relation("SellerCommissionTiers")
  sellerGoals                SellerGoal[]
  serviceOrdersCreated       ServiceOrder[]           @relation("SOCreator")
  serviceOrdersDelivered     ServiceOrder[]           @relation("SODeliverer")
  soHistoryChanges           ServiceOrderHistory[]    @relation("SOHistoryChanger")
  stockAdjustmentsApproved   StockAdjustment[]        @relation("AdjustmentApprover")
  stockAdjustmentsCreated    StockAdjustment[]        @relation("AdjustmentCreator")
  stockMovements             StockMovement[]
  supportTickets             SupportTicket[]
  companyNotifications       CompanyNotification[]
  company                    Company                  @relation(fields: [companyId], references: [id])
  branches                   UserBranch[]
  customPermissions          UserPermission[]         @relation("UserCustomPermissions")
  goalsCreated               ContactGoal[]            @relation("GoalCreator")
  userGoals                  ContactGoal[]            @relation("UserGoals")
  crmContactsMade            CrmContact[]             @relation("CrmContactsMade")
  assignedReminders          CustomerReminder[]       @relation("AssignedReminders")
  templatesCreated           MessageTemplate[]        @relation("TemplateCreator")
  transfersApproved          StockTransfer[]          @relation("TransferApprover")
  transfersRequested         StockTransfer[]          @relation("TransferRequester")
  leadsAsSeller              Lead[]                   @relation("LeadSeller")

  @@index([companyId, email])
  @@index([companyId, role])
  @@index([companyId, name])
}

model UserBranch {
  userId   String
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])
  user     User   @relation(fields: [userId], references: [id])

  @@id([userId, branchId])
}

model AuditLog {
  id         String   @id @default(cuid())
  companyId  String
  branchId   String?
  userId     String?
  action     String
  entityType String
  entityId   String
  oldData    Json?
  newData    Json?
  ip         String?
  createdAt  DateTime @default(now())
  branch     Branch?  @relation(fields: [branchId], references: [id])
  company    Company  @relation(fields: [companyId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])

  @@index([companyId, createdAt])
  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@index([branchId, createdAt])
}

model Customer {
  id                 String                 @id @default(cuid())
  companyId          String
  name               String
  cpf                String?
  rg                 String?
  phone              String?
  phone2             String?
  // Chave canônica do telefone (DDD+8díg) p/ casar contato do WhatsApp↔cliente.
  // Derivada de phone (e phone2) via phoneMatchKey no write + backfill. Índice
  // COMPOSTO com companyId — nunca buscar por phoneNormalized sem companyId.
  phoneNormalized    String?
  phone2Normalized   String?
  email              String?
  birthDate          DateTime?
  gender             String?
  address            String?
  number             String?
  complement         String?
  neighborhood       String?
  city               String?
  state              String?
  zipCode            String?
  acceptsMarketing   Boolean                @default(true)
  referralSource     String?
  notes              String?
  active             Boolean                @default(true)
  deletedAt          DateTime?
  // LGPD compliance
  anonymizedAt       DateTime?              // dados pessoais anonimizados (mantém integridade FK)
  lgpdConsentAt      DateTime?              // último consentimento registrado
  lgpdConsentVersion String?                // versão do termo aceito
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  cnpj               String?
  companyName        String?
  personType         String                 @default("PF")
  tradeName          String?
  externalId         String?
  originBranchId     String?                @map("origin_branch_id")
  // Limite de crédito individual (sobrepõe SystemRule customers.default_credit_limit)
  // null = usa o default da empresa. Adicionado no Bug #3 fix.
  creditLimit            Decimal?  @db.Decimal(12, 2)
  creditLimitOverridden  Boolean   @default(false)
  accountsReceivable AccountReceivable[]
  agreementBenefits  AgreementBeneficiary[]
  company            Company                @relation(fields: [companyId], references: [id])
  originBranch       Branch?                @relation("BranchOriginCustomers", fields: [originBranchId], references: [id])
  cashback           CustomerCashback[]
  contacts           CustomerContact[]
  loyaltyPoints      LoyaltyPoints[]
  prescriptions      Prescription[]
  quotes             Quote[]
  refunds            Refund[]
  reminders          Reminder[]
  sales              Sale[]
  serviceOrders      ServiceOrder[]
  crmContacts        CrmContact[]           @relation("CrmContacts")
  crmReminders       CustomerReminder[]     @relation("CustomerReminders")
  whatsappMessages   WhatsappMessageLog[]
  consentRecords     ConsentRecord[]
  accessLogs         CustomerAccessLog[]
  leads              Lead[]                 @relation("LeadCustomer")
  leadsSuggested     Lead[]                 @relation("LeadSuggestedCustomer")

  @@unique([companyId, cpf])
  // cnpj: único POR EMPRESA via índice PARCIAL (WHERE cnpj IS NOT NULL) criado na
  // migration 20260609190000_customer_cnpj_unique_partial — NÃO declarado como
  // @@unique aqui de propósito (mesmo padrão de email/User.email), senão o Prisma
  // esperaria um índice completo (Customer_companyId_cnpj_key) e acusaria drift.
  // Aplicação trata P2002 + findFirst preventivo em customer.service.ts.
  @@index([companyId, name])
  @@index([companyId, phone])
  @@index([companyId, email])
  @@index([originBranchId])
  // Match de contato↔cliente: SEMPRE composto com companyId (multi-tenant).
  @@index([companyId, phoneNormalized])
  @@index([companyId, phone2Normalized])
}

/// Registro de consentimento LGPD (Art. 8º). Auditável e imutável após criação.
model ConsentRecord {
  id           String   @id @default(cuid())
  customerId   String
  companyId    String
  /// Versão do termo aceito (ex: "v1.0", "2026-05-25")
  termVersion  String
  /// Escopo do consentimento: ex "marketing,health_data,personal_data"
  scope        String
  /// IP do navegador no momento do aceite
  ipAddress    String?
  /// User-Agent
  userAgent    String?
  acceptedAt   DateTime @default(now())
  /// Se revogado, quando
  revokedAt    DateTime?
  customer     Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, acceptedAt])
  @@index([companyId, acceptedAt])
}

/// Log de acesso a dados pessoais de cliente (auditoria LGPD Art. 37).
/// Apenas para operações sensíveis (visualizar receita, exportar dados).
model CustomerAccessLog {
  id           String   @id @default(cuid())
  companyId    String
  customerId   String
  userId       String?
  /// Tipo de recurso acessado: "prescription" | "personal_data" | "export"
  resourceType String
  /// ID do recurso acessado (ex: PrescriptionValues.id)
  resourceId   String?
  /// Ação: "view" | "edit" | "export" | "delete"
  action       String
  ipAddress    String?
  createdAt    DateTime @default(now())
  customer     Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, createdAt])
  @@index([companyId, createdAt])
  @@index([userId, createdAt])
}

model Doctor {
  id                       String         @id @default(cuid())
  companyId                String
  name                     String
  crm                      String?
  uf                       String?
  specialty                String?
  isPartner                Boolean        @default(false)
  partnerCommissionPercent Decimal?       @db.Decimal(5, 2)
  phone                    String?
  email                    String?
  clinicName               String?
  clinicAddress            String?
  active                   Boolean        @default(true)
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  company                  Company        @relation(fields: [companyId], references: [id])
  prescriptions            Prescription[]

  @@unique([companyId, crm, uf])
  @@index([companyId, name])
}

model Lab {
  id                  String              @id @default(cuid())
  companyId           String
  name                String
  code                String?
  cnpj                String?
  phone               String?
  email               String?
  orderEmail          String?
  website             String?
  contactPerson       String?
  integrationType     String?
  apiUrl              String?
  apiKey              String?
  clientCode          String?
  defaultLeadTimeDays Int                 @default(7)
  urgentLeadTimeDays  Int                 @default(3)
  paymentTermDays     Int                 @default(30)
  defaultDiscount     Decimal             @default(0) @db.Decimal(5, 2)
  qualityRating       Decimal?            @db.Decimal(3, 2)
  totalOrders         Int                 @default(0)
  totalReworks        Int                 @default(0)
  active              Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  company             Company             @relation(fields: [companyId], references: [id])
  priceRanges         LabPriceRange[]
  lensServices        LensServiceDetail[]
  serviceOrders       ServiceOrder[]
  serviceOrderItems   ServiceOrderItem[]

  @@unique([companyId, code])
  @@index([companyId, name])
}

model LensTreatment {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation("CompanyLensTreatments", fields: [companyId], references: [id])

  @@unique([companyId, name])
  @@index([companyId, active])
}

model LabPriceRange {
  id                String   @id @default(cuid())
  labId             String
  lensType          String
  material          String
  sphMin            Decimal? @db.Decimal(5, 2)
  sphMax            Decimal? @db.Decimal(5, 2)
  cylMin            Decimal? @db.Decimal(5, 2)
  cylMax            Decimal? @db.Decimal(5, 2)
  labPrice          Decimal  @db.Decimal(12, 2)
  suggestedPrice    Decimal? @db.Decimal(12, 2)
  arPrice           Decimal? @db.Decimal(12, 2)
  blueLightPrice    Decimal? @db.Decimal(12, 2)
  photochromicPrice Decimal? @db.Decimal(12, 2)
  leadTimeDays      Int?
  active            Boolean  @default(true)
  lab               Lab      @relation(fields: [labId], references: [id])

  @@index([labId, lensType, material])
}

model Supplier {
  id              String                @id @default(cuid())
  companyId       String
  name            String
  tradeName       String?
  cnpj            String?
  phone           String?
  email           String?
  website         String?
  contactPerson   String?
  address         String?
  city            String?
  state           String?
  zipCode         String?
  notes           String?
  active          Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  accountsPayable    AccountPayable[]
  inventoryLots      InventoryLot[]        @relation("LotSupplier")
  products           Product[]
  campaignItems      ProductCampaignItem[]
  stockMovements     StockMovement[]
  recurringExpenses  RecurringExpense[]
  company            Company               @relation(fields: [companyId], references: [id])

  @@unique([companyId, cnpj])
  @@index([companyId, name])
}

model Category {
  id                       String                @id @default(cuid())
  companyId                String
  name                     String
  parentId                 String?
  defaultCommissionPercent Decimal?              @db.Decimal(5, 2)
  minMarginPercent         Decimal?              @db.Decimal(5, 2)
  active                   Boolean               @default(true)
  company                  Company               @relation(fields: [companyId], references: [id])
  parent                   Category?             @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children                 Category[]            @relation("CategoryHierarchy")
  products                 Product[]
  campaignItems            ProductCampaignItem[]

  @@unique([companyId, name])
}

model Brand {
  id            String                @id @default(cuid())
  companyId     String
  code          String
  name          String
  manufacturer  String?
  minMargin     Decimal?              @db.Decimal(5, 2)
  maxDiscount   Decimal?              @db.Decimal(5, 2)
  segment       String?
  origin        String?
  logoPath      String?
