  lastRunAt      DateTime?
  lastRunSummary Json?
  updatedBy      String?
  updatedAt      DateTime  @updatedAt
}

model PlanInterest {
  id          String   @id @default(cuid())
  planSlug    String
  name        String
  email       String
  phone       String?
  companyName String?
  createdAt   DateTime @default(now())

  @@unique([email, planSlug])
  @@index([planSlug])
  @@index([createdAt])
}

/// Tipos de email transacional do ciclo de vida da assinatura (Fase 1 + Fase 2).
enum SaasEmailType {
  WELCOME
  TRIAL_ENDING
  TRIAL_EXPIRED
  INVOICE_OVERDUE
  PAYMENT_CONFIRMED
  SUBSCRIPTION_SUSPENDED
  SUBSCRIPTION_CANCELED
  // Gerados pelo fluxo de cobrança Asaas (Fase Email-A). O valor já existe no
  // enum do banco de prod (migration 20260611120000).
  INVOICE_CREATED
  INVOICE_DUE_SOON
}

enum SaasEmailLogStatus {
  PENDING
  SENT
  SKIPPED
  FAILED
}

/// Config global dos emails do SaaS. Registro ÚNICO (id fixo "singleton" via
/// upsert no service). Flags liga/desliga por tipo + modo teste. Entregue com
/// testMode LIGADO (emails vão só p/ testEmail até o dono desligar).
model SaasEmailConfig {
  id                           String   @id
  masterEnabled                Boolean  @default(true)
  testMode                     Boolean  @default(true)
  testEmail                    String?
  welcomeEnabled               Boolean  @default(true)
  trialEndingEnabled           Boolean  @default(true)
  trialExpiredEnabled          Boolean  @default(true)
  invoiceOverdueEnabled        Boolean  @default(true)
  paymentConfirmedEnabled      Boolean  @default(true)
  subscriptionSuspendedEnabled Boolean  @default(true)
  subscriptionCanceledEnabled  Boolean  @default(true)
  invoiceGenerationEnabled     Boolean  @default(false)
  invoiceCreatedEnabled        Boolean  @default(true)
  invoiceDueSoonEnabled        Boolean  @default(true)
  updatedBy                    String?
  updatedAt                    DateTime @updatedAt
}

/// Histórico + chave de idempotência de cada notificação do SaaS disparada.
/// A unique (companyId, eventType, periodKey) impede reenviar o mesmo evento
/// no mesmo período (ex.: "vencida 7d" uma vez só; trial ending uma vez só).
model SaasEmailLog {
  id           String             @id @default(cuid())
  companyId    String
  eventType    SaasEmailType
  periodKey    String
  to           String
  status       SaasEmailLogStatus @default(PENDING)
  channels     String             @default("email")
  emailQueueId String?
  skipReason   String?
  createdAt    DateTime           @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, eventType, periodKey])
  @@index([companyId, createdAt])
  @@index([eventType, createdAt])
}

/// Contadores globais do SaaS (ex.: sequência de número de fatura "INV-NNNNNN").
/// SEM FK de Company — é uma tabela de sequências globais.
model SaasCounter {
  key   String @id
  value Int    @default(0)
}

/// Conexão de WhatsApp de uma ótica com a Evolution API (Fase B1).
///
/// 1:1 com Company (uma instância de WhatsApp por ótica). O nome da instância
/// na Evolution é SEMPRE derivado do companyId (`vis_${companyId}`) — nunca de
/// algo vindo do client — garantindo isolamento entre óticas: o webhook resolve
/// a empresa pelo `instanceName` único.
///
/// Esta fase guarda apenas a CONEXÃO e o status (sem motor de mensagens/fila —
/// isso é a Fase B2).
model WhatsappConnection {
  id              String                 @id @default(cuid())
  companyId       String                 @unique
  /// Reservado para o futuro (conexão por filial). Não usado nesta fase.
  branchId        String?
  /// Nome da instância na Evolution, derivado do companyId. Único globalmente.
  instanceName    String                 @unique
  /// API key escopada à instância (hash retornado no create). Nullable e NÃO
  /// usada nas chamadas nesta fase — usamos sempre a chave global. Não criptografada.
  instanceApiKey  String?
  status          WhatsappConnStatus     @default(DISCONNECTED)
  /// Número conectado (somente dígitos, ex: 5511999999999).
  connectedNumber String?
  /// Momento em que o número MUDOU de fato (troca de chip), distinto de
  /// connectedAt (que é regravado em toda reconexão, inclusive queda de sinal).
  /// É o CORTE do arquivamento de conversas do número antigo — usar connectedAt
  /// aqui arquivaria o funil inteiro numa simples reconexão.
  numberChangedAt DateTime?
  /// CORTE da qualificação por IA: quando setado, o cron só qualifica conversas
  /// com lastMessageAt >= qualifyFromAt — ou seja, "só daqui pra frente". Serve
  /// para zerar o backlog acumulado (ex.: após troca de número ou estouro de cota)
  /// sem gastar cota reprocessando conversas antigas. null = sem corte (qualifica
  /// tudo que estiver pendente, comportamento original). Setado por botão no admin.
  qualifyFromAt   DateTime?
  lastQrAt        DateTime?
  connectedAt     DateTime?
  disconnectedAt  DateTime?
  /// Último webhook recebido da Evolution (para dedupe/diagnóstico).
  lastEventAt     DateTime?
  lastError       String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  company         Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([status])
}

model WhatsappConversation {
  id            String    @id @default(cuid())
  companyId     String
  contactNumber String
  contactName      String?
  isGroup          Boolean   @default(false)  // remoteJid terminava em @g.us; grupos NÃO viram lead
  needsAnalysis    Boolean   @default(false)  // msg nova chegou após analyzedAt → re-qualificar (R1)
  // Re-avaliação do ESTÁGIO do funil (barata, sem IA), separada de needsAnalysis
  // (que re-classifica a intenção via Claude — caro). Armado quando a ÓTICA RESPONDE
  // (outbound) numa conversa que já é lead: o sinal shopReplied só vira true no
  // outbound, mas o outbound NÃO re-arma needsAnalysis (a intenção não muda porque
  // respondemos). Sem este flag, o card fica preso em "Novo" apesar de atendido —
  // a régua nunca era re-avaliada. O cron roda SÓ a régua objetiva e limpa o flag.
  needsFunnelEval  Boolean   @default(false)
  analysisAttempts Int       @default(0)      // anti-loop: cron só pega < 3 (R2)
  lastMessageAt DateTime  @default(now())
  analyzedAt    DateTime?
  leadId        String?
  // Resultado da última análise da IA — preenchido SEMPRE (vire lead ou não),
  // p/ o dono ver no inbox POR QUE a conversa foi classificada assim. Antes o
  // motivo era descartado no caminho não-lead. analysisIntent/CustomerKind são
  // strings (rótulos) p/ exibição — não acoplam ao enum.
  analysisIsLead       Boolean?
  analysisIntent       String?
  // Intenção CRUA (enum) da última análise — o sinal MÁQUINA-legível. analysisIntent
  // guarda só o RÓTULO ("Reclamação"), que é artefato de exibição e deriva ao renomear;
  // um guardrail (~100% recall) precisa do valor recuperável no disco. Sempre sobrescrito.
  analysisIntentCode   ContactIntent?
  analysisCustomerKind String?
  analysisReason       String?
  // Guardrail SAGRADO da reclamação (Item 1). true = a conversa precisa de um
  // humano AGORA (reclamação/cobrança OU tom irritado). É MONOTÔNICO-PRA-CIMA:
  // a re-qualificação NUNCA volta p/ false (senão o cliente desarma o alarme só
  // mandando "ok obrigado"). Baixa = ação HUMANA explícita e auditada (abaixo).
  // Ver src/lib/conversation-attention.ts (fonte única, pura, usada por prod+eval).
  needsHumanAttention  Boolean   @default(false)
  attentionResolvedAt   DateTime? // quando um humano deu baixa no alarme
  attentionResolvedById String?   // quem deu baixa (trilha de auditoria do R$50k)
  // Arquivamento (troca de número da loja): conversa arquivada = fora do funil
  // ativo (inbox/Recuperar/filas de automação), mas PRESERVADA no banco p/
  // histórico/LGPD. Setado em lote quando a loja troca o número de WhatsApp — as
  // conversas do número antigo não podem mais ser respondidas por ali, então
  // saem do dia a dia. null = ativa. Reversível (desarquivar = voltar a null).
  archivedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company  Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  messages WhatsappMessage[]

  @@unique([companyId, contactNumber])
  @@index([companyId, lastMessageAt])
  @@index([companyId, analyzedAt])
  @@index([companyId, isGroup, analyzedAt])
  // Índice p/ o inbox listar/ordenar os que precisam de atenção sem table-scan.
  @@index([companyId, needsHumanAttention])
  // Item 5: o SLA afiado ("precisa responder") busca conversas por leadId (in).
  // Sem este índice, a busca vira scan filtrado por companyId conforme a ótica cresce.
  @@index([companyId, leadId])
  // O cron varre conversas com re-avaliação de funil pendente sem table-scan.
  @@index([companyId, needsFunnelEval])
  // Inbox/filas filtram archivedAt=null e ordenam por lastMessageAt — índice
  // parcial-friendly p/ não varrer arquivadas conforme o histórico cresce.
  @@index([companyId, archivedAt, lastMessageAt])
}

model WhatsappMessage {
  id             String   @id @default(cuid())
  conversationId String
  companyId      String
  direction      String   // "inbound" | "outbound"
  type           String   // "text" | "audio" | "image" | "other"
  text           String?
  mediaUrl       String?
  evolutionId    String?  @unique
  receivedAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  conversation WhatsappConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([companyId, conversationId])
  @@index([conversationId, receivedAt])
}

enum WhatsappConnStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
  FAILED
}

/// Outbox de mensagens de WhatsApp enviadas pelo motor (Fase B2).
///
/// Fonte da verdade de TODO envio (manual ou automático): registra SENT/FAILED/
/// SKIPPED com o motivo. Idempotência via @@unique(companyId, type, referenceId,
/// periodKey) — no Postgres NULLs são distintos no índice único, então envios
/// manuais (periodKey null) nunca colidem; só os automáticos (que preenchem
/// periodKey) ficam protegidos de reenvio. Molde: SaasEmailLog.
///
/// LGPD: `content` guarda só o texto efetivamente enviado (nome, nº OS, valor,
/// vencimento) — NUNCA grau/receita/dado clínico.
model WhatsappMessageLog {
  id                 String                @id @default(cuid())
  companyId          String
  customerId         String?
  type               WhatsappMessageType
  phone              String
  content            String
  status             WhatsappMessageStatus
  /// Motivo quando SKIPPED (feature_off, not_connected, no_consent, no_phone, already_sent).
  skipReason         String?
  /// Erro quando FAILED (mensagem do provedor/rede).
  error              String?
  /// Id da mensagem retornado pela Evolution (quando SENT).
  evolutionMessageId String?
  /// Id da entidade de origem (saleId, serviceOrderId, accountReceivableId, customerId…).
  referenceId        String?
  /// Janela de dedupe para envios automáticos (ex.: "2026-06-15"). Null = manual.
  periodKey          String?
  createdAt          DateTime              @default(now())
  sentAt             DateTime?
  /// Quando a linha foi travada (claim PENDING→PROCESSING) pelo processador da
  /// fila. Usado p/ detectar PROCESSING preso (recuperação de stale) — NÃO usar
  /// createdAt (= hora do enfileiramento), senão linhas que esperaram na fila
  /// >STALE_MIN seriam recuperadas mid-envio e reenviadas.
  processingAt       DateTime?

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id])

  @@unique([companyId, type, referenceId, periodKey])
  @@index([companyId, createdAt])
  @@index([companyId, type, status])
  @@index([customerId])
}

model AiTokenUsage {
  id           String   @id @default(cuid())
  companyId    String?
  feature      String   // "ocr_prescription" | "lead_qualification" | "audio_transcription"
  provider     String   // "anthropic" | "openai"
  model        String
  inputTokens      Int      @default(0)
  outputTokens     Int      @default(0)
  cacheTokens      Int      @default(0) // cache_read_input_tokens (leitura de cache)
  cacheWriteTokens Int      @default(0) // cache_creation_input_tokens (escrita de cache)
  audioSeconds     Int?
  costUsd          Decimal  @default(0) @db.Decimal(12, 6)
  createdAt        DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([companyId, feature])
}

/// Base de conhecimento do Assistente de Lentes (Fase 2). Só super admin edita.
/// companyId null = GLOBAL (vale p/ todas as óticas); preenchido = só daquela ótica.
model LensKnowledgeDoc {
  id               String   @id @default(cuid())
  companyId        String?
  title            String
  content          String   @db.Text
  tokensEstimate   Int      @default(0)
  active           Boolean  @default(true)
  createdByAdminId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([companyId, active])
}

/// Config global de IA do SaaS (singleton: 1 linha, id fixo "global").
/// Só o super admin edita. anthropicKeyEnc é cifrada (secret-cipher).
