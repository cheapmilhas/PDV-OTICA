// ============================================================================
// COMISSÃO POR NÍVEIS (mini/meta/mega) — Bloco 4 / Comissão Fase 1
// ============================================================================
//
// Estrutura nova (não existia): guarda os 3 níveis de meta por vendedor que
// definem a "comissão de meta". O vendedor atinge um nível quando o total
// vendido líquido no mês ≥ targetAmount; vale o % do MAIOR nível atingido,
// aplicado RETROATIVAMENTE sobre tudo que vendeu.
//
// Padrão default+override (espelha AiGlobalConfig/getEffectiveMarkup):
//   - userId = null  → DEFAULT da ótica (companyId): vale p/ todo vendedor
//                      sem config própria.
//   - userId = <id>  → OVERRIDE daquele vendedor: tem precedência sobre o
//                      default da ótica.
// Os 3 níveis de um mesmo escopo (default ou um vendedor) são 3 linhas, uma
// por `level`. A unicidade garante no máximo 1 linha por (empresa, escopo,
// nível).
//
// NÃO substitui SellerGoal/SalesGoal (meta de venda exibida na tela) nem
// CommissionConfig (% por filial legado) — convive. A unificação/limpeza das
// fontes antigas é fase posterior; aqui só se CRIA a fundação. O motor de
// cálculo (commission-engine) lê desta tabela; nenhuma tela grava nela ainda.
model SellerCommissionTier {
  id           String              @id @default(cuid())
  companyId    String
  // null = default da ótica; preenchido = override do vendedor.
  userId       String?
  level        CommissionTierLevel
  // Valor-alvo em R$ que precisa ser atingido (total vendido líquido no mês).
  targetAmount Decimal             @db.Decimal(12, 2)
  // % aplicado retroativamente sobre TUDO que o vendedor vendeu no mês quando
  // este é o maior nível atingido.
  percent      Decimal             @db.Decimal(5, 2)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  company      Company             @relation(fields: [companyId], references: [id])
  // onDelete: Cascade — apagar um vendedor APAGA as metas dele. NUNCA virar
  // userId=null (que seria "promover" o override do vendedor a default da
  // ótica). Decisão do Matheus na revisão da Fase 1.
  user         User?               @relation("SellerCommissionTiers", fields: [userId], references: [id], onDelete: Cascade)

  // 1 linha por (empresa, escopo, nível). NULL em userId conta como um valor
  // distinto no índice único do Postgres → o default da ótica ocupa um slot
  // próprio por nível, sem colidir com os overrides dos vendedores.
  //
  // ⚠️ Esse @@unique NÃO protege o DEFAULT da ótica: no Postgres dois NULL são
  // "distintos", então (co, NULL, MINI) pode duplicar. A migração adiciona um
  // ÍNDICE ÚNICO PARCIAL (WHERE userId IS NULL) p/ fechar esse buraco — ele não
  // é expressável aqui (Prisma não tem unique parcial declarativo), por isso o
  // schema documenta e a migração materializa.
  @@unique([companyId, userId, level])
  @@index([companyId])
  @@index([userId])
}

// Os 3 níveis individuais de meta (ordem crescente de exigência).
enum CommissionTierLevel {
  MINI
  META
  MEGA
}

