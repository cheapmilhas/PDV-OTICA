model Prescription {
  id               String              @id @default(cuid())
  companyId        String
  customerId       String
  doctorId         String?
  issuedAt         DateTime
  expiresAt        DateTime
  prescriptionType String?
  notes            String?
  imageUrl         String?
  createdByUserId  String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  branchId         String?             @map("branch_id")

  // ── Livro de Receitas (Fase 1) ───────────────────────────────────────────
  // Estado de preenchimento do grau. Default seguro: receita nova sem grau.
  status                PrescriptionStatus @default(AGUARDANDO_GRAU)
  // Foto arquivada da receita (1 por enquanto). Guarda o CAMINHO/URL da imagem.
  // Storage NÃO é implementado nesta fase — só o campo. Ver imageUrl (legado do
  // model dormente) que segue existindo; este é o campo oficial do Livro.
  prescriptionImageUrl  String?
  // Paciente/dependente: quem USA a receita pode não ser quem paga (titular).
  isDependente          Boolean         @default(false)
  patientName           String?
  patientBirthDate      DateTime?
  // Vínculos de ORIGEM (nullable). A origem da receita é inferida por qual
  // vínculo está preenchido: veio de uma OS (serviceOrderId), de uma venda
  // direta (saleId), ou foi avulsa (ambos null). onDelete: SetNull — a receita
  // PERSISTE no Livro mesmo que a OS/venda de origem seja apagada.
  serviceOrderId   String?
  // saleId é a CHAVE DE UNICIDADE do Livro: 1 venda → no máximo 1 receita.
  // @unique impede duplicidade em corrida (NULL não colide no Postgres, então
  // receitas avulsas sem venda convivem). Habilita upsert por saleId.
  saleId           String?             @unique

  branch           Branch?             @relation(fields: [branchId], references: [id])
  company          Company             @relation(fields: [companyId], references: [id])
  createdByUser    User?               @relation("PrescriptionCreator", fields: [createdByUserId], references: [id])
  customer         Customer            @relation(fields: [customerId], references: [id])
  doctor           Doctor?             @relation(fields: [doctorId], references: [id])
  values           PrescriptionValues?
  // Vínculo histórico já existente (1 receita → N OS que a referenciam por
  // prescriptionId). Mantido intacto. NÃO confundir com serviceOrderId acima,
  // que é o vínculo de ORIGEM (a OS que gerou esta receita no Livro).
  serviceOrders    ServiceOrder[]      @relation("SOPrescription")
  // Vínculo de origem (SetNull on delete) — back-relations dedicadas.
  originServiceOrder ServiceOrder?     @relation("PrescriptionOriginSO", fields: [serviceOrderId], references: [id], onDelete: SetNull)
  originSale         Sale?             @relation("PrescriptionOriginSale", fields: [saleId], references: [id], onDelete: SetNull)

  @@index([companyId, customerId])
  @@index([customerId, expiresAt])
  @@index([branchId])
  @@index([companyId, status])
  @@index([serviceOrderId])
}

