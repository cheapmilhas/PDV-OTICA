  anthropicKeyEnc String?
  openaiKeyEnc    String?
  qualifierModel  String   @default("claude-haiku-4-5")
  lensAdvisorModel String  @default("claude-haiku-4-5")
  ocrModel        String   @default("claude-sonnet-4-6")
  usdBrlRate      Decimal  @default(5.5) @db.Decimal(10, 4)
  markupPercent   Decimal  @default(0)   @db.Decimal(6, 2)
  creditTokenFactor Int    @default(1000)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

/// Config global (singleton id="global") das travas anti-bloqueio do WhatsApp
/// (Fase 2). Defaults = valores hardcoded da Fase 1 → comportamento idêntico até
/// alguém editar. Override por ótica vive em CompanySettings.wa*Override.
model WhatsappGlobalConfig {
  id           String   @id @default("global")
  openHour     Int      @default(8)
  closeHour    Int      @default(18)
  dailyCap     Int      @default(50)
  skipSaturday Boolean  @default(false)
  staleMin     Int      @default(10)
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}

