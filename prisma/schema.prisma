  reworkReason      String?
  medicalErrorReason String?
  // Sequência de exibição por (OS original + tipo): G1, G2, RT1, M1...
  // O number interno continua único/sequencial; isto é só p/ exibição #1234-G1.
  warrantySeq       Int?
  originalOrderId   String?
  deliveredByUserId String?
  deliveryNotes     String?
  qualityRating     Int?
  qualityNotes      String?
  prescriptionData     Json?
  prescriptionImageUrl String?
  lensType             String?
  lensDescription      String?
  lensColoring         String?
  treatments           String[]
  notes                String?
  deletedAt            DateTime?
